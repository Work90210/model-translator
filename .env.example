# ============================================
# Database
# ============================================
# For local Docker:  postgresql://mt:REPLACE_ME@localhost:5432/apifold
# For Neon:          postgresql://user:pass@ep-xyz.us-east-2.aws.neon.tech/apifold?sslmode=require
# For Supabase:      postgresql://postgres.xyz:pass@aws-0-us-east-1.pooler.supabase.com:6543/postgres
# For AWS RDS:       postgresql://mt:pass@mydb.cluster-xyz.us-east-1.rds.amazonaws.com:5432/apifold?sslmode=require
DATABASE_URL=postgresql://mt:REPLACE_ME@localhost:5432/apifold
# Connection pool size (default: 20, reduce to 5-10 for serverless providers like Neon)
DATABASE_POOL_MAX=20
# Set to "true" to enable SSL for database connections (auto-detected from sslmode= in URL)
DATABASE_SSL=false
# Set to "false" only for self-signed certs in development
DATABASE_SSL_REJECT_UNAUTHORIZED=true
# Read replica connection URL (optional, for multi-region read scaling)
DATABASE_READ_URL=
POSTGRES_DB=apifold
POSTGRES_USER=mt
POSTGRES_PASSWORD=REPLACE_ME

# ============================================
# Redis
# ============================================
# For local Docker:   redis://:password@localhost:6379
# For Upstash:        rediss://default:token@us1-xyz.upstash.io:6379
# For AWS ElastiCache: redis://my-cluster.xyz.use1.cache.amazonaws.com:6379
# For Redis Cloud:    redis://default:pass@redis-12345.c1.us-east-1-1.ec2.cloud.redislabs.com:12345
REDIS_PASSWORD=change-me-to-a-strong-redis-password
REDIS_URL=redis://:change-me-to-a-strong-redis-password@localhost:6379
# Force TLS (auto-detected from rediss:// URL scheme)
REDIS_TLS=false
# Max reconnection attempts (default: 10)
REDIS_MAX_RETRIES=10

# ============================================
# Security
# ============================================
# AES-256-GCM credential encryption key (PBKDF2-derived)
# Must be at least 32 characters. Generate with: openssl rand -base64 48
VAULT_SECRET=REPLACE_ME
# Per-installation PBKDF2 salt. Generate once with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VAULT_SALT=REPLACE_ME

# ============================================
# Inter-Service Auth
# ============================================
# Shared secret for web app → runtime internal calls
# Must be at least 32 characters. Generate with: openssl rand -base64 48
MCP_RUNTIME_SECRET=REPLACE_ME

# ============================================
# App
# ============================================
NODE_ENV=development
PORT=3000
RUNTIME_PORT=3001
# Public URL of the runtime (for MCP endpoint URLs shown in the dashboard)
# In combined deployment: http://localhost:3001 or same domain via Nginx
# In split deployment: https://runtime.apifold.dev
RUNTIME_PUBLIC_URL=http://localhost:3001

# ============================================
# Runtime SSE Configuration
# ============================================
# Maximum concurrent SSE sessions (default: 10000)
MAX_SSE_SESSIONS=10000
# Heartbeat interval in ms (default: 30000)
SSE_HEARTBEAT_INTERVAL_MS=30000
# Idle session timeout in ms (default: 300000 = 5 min)
SSE_IDLE_TIMEOUT_MS=300000

# ============================================
# Runtime Resilience
# ============================================
# Circuit breaker failure threshold before opening (default: 5)
CIRCUIT_BREAKER_THRESHOLD=5
# Circuit breaker cooldown in ms before half-open (default: 30000)
CIRCUIT_BREAKER_COOLDOWN_MS=30000
# Upstream API call timeout in ms (default: 30000)
UPSTREAM_TIMEOUT_MS=30000

# ============================================
# Runtime Caching
# ============================================
# Credential cache TTL in ms (default: 300000 = 5 min)
CREDENTIAL_TTL_MS=300000
# Fallback Postgres poll interval when Redis is down (default: 30000)
FALLBACK_POLL_INTERVAL_MS=30000

# ============================================
# Runtime CORS
# ============================================
# Comma-separated allowed origins. MUST be set to specific origins in production.
# Example: CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=http://localhost:3000

# ============================================
# Runtime Rate Limiting
# ============================================
# Global rate limit window in ms (default: 900000 = 15 min)
GLOBAL_RATE_LIMIT_WINDOW_MS=900000
# Global rate limit max requests per window (default: 1000)
GLOBAL_RATE_LIMIT_MAX=1000

# ============================================
# Runtime Shutdown
# ============================================
# Graceful shutdown drain timeout in ms (default: 30000)
DRAIN_TIMEOUT_MS=30000

# ============================================
# Runtime Cluster
# ============================================
# Number of worker processes (default: 4, max: 8)
RUNTIME_MAX_WORKERS=4
# Grace period in ms for graceful shutdown (default: 10000)
RUNTIME_SHUTDOWN_GRACE_MS=10000
# Health check port for cluster primary (default: 9090)
RUNTIME_HEALTH_PORT=9090
# Max SSE connections per worker process (default: 100)
RUNTIME_MAX_CONNECTIONS_PER_WORKER=100

# ============================================
# CDN
# ============================================
# CDN URL for static assets (leave empty for self-hosted/same-origin)
CDN_URL=

# ============================================
# Logging
# ============================================
# Log level: fatal, error, warn, info, debug, trace (default: info)
LOG_LEVEL=info
