    "postgres": "^3.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@apifold/eslint-config": "workspace:*",
    "@apifold/tsconfig": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^8.57.0",
